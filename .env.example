# Copy to .env and fill in. .env is gitignored.
# See docs/ARCHITECTURE.md §6 for what each var does.

# dev = read templates/static from disk + re-parse per request; prod = embedded
APP_ENV=dev

# Bind address inside the process (container binds 0.0.0.0; compose publishes to host loopback)
LISTEN_ADDR=:8080

# Builds virtual-host keys. Use "localhost" in dev, "corpberry.com" in prod.
BASE_DOMAIN=localhost

# IP2Location LITE database paths (gitignored data; bind-mounted in prod as /assets)
IP2LOCATION_DB11_V4=iptolocation/assets/ipv4/IP2LOCATION-LITE-DB11.BIN
IP2LOCATION_DB11_V6=iptolocation/assets/ipv6/IP2LOCATION-LITE-DB11.IPV6.BIN
IP2LOCATION_ASN_V4=iptolocation/assets/asn/IP2LOCATION-LITE-ASN.BIN
IP2LOCATION_ASN_V6=iptolocation/assets/asn/IP2LOCATION-LITE-ASN.IPV6.BIN

# Used only by `make assets` to download the BINs — NOT read by the app.
IP2LOCATION_DOWNLOAD_TOKEN=
IP2LOCATION_SITE_URL=
