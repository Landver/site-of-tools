# Copy to .env and fill in. .env is gitignored.
# See docs/ARCHITECTURE.md §6 for what each var does.
#
# .env holds the base (dev) values and is also loaded by the container. For prod,
# docker-compose layers a .env.prod on top of .env with just the overrides:
#     APP_ENV=prod
#     BASE_DOMAIN=corpberry.com
# .env.prod is gitignored (per-host, like .env) — create it on deploy. Keep all
# values in the env files; do not restate them in docker-compose.yml.

# dev = read templates/static from disk + re-parse per request; prod = embedded
APP_ENV=dev

# Bind address inside the process (container binds 0.0.0.0; compose publishes to host loopback)
LISTEN_ADDR=:8080

# Builds virtual-host keys. Use "localhost" in dev, "corpberry.com" in prod.
BASE_DOMAIN=localhost

# IP2Location LITE database paths (gitignored data; bind-mounted in prod as /assets)
IP2LOCATION_DB11_V4=iptools/assets/ipv4/IP2LOCATION-LITE-DB11.BIN
IP2LOCATION_DB11_V6=iptools/assets/ipv6/IP2LOCATION-LITE-DB11.IPV6.BIN
IP2LOCATION_ASN_V4=iptools/assets/asn/IP2LOCATION-LITE-ASN.BIN
IP2LOCATION_ASN_V6=iptools/assets/asn/IP2LOCATION-LITE-ASN.IPV6.BIN

# IP2Proxy PX12 (proxy/VPN/threat). Optional — omit to disable the proxy section.
IP2PROXY_PX12=iptools/assets/ip2proxy/IP2PROXY-LITE-PX12.BIN

# Used only by `make assets` to download the BINs — NOT read by the app.
IP2LOCATION_DOWNLOAD_TOKEN=

# MongoDB — the shared server (mongodb.corpberry.com). The path segment is the
# AUTH database (/admin); the APP database is MONGODB_DATABASE below. Unlike the
# IP2Location BINs this is a network dependency, not a bind-mounted file, so the
# same URI works from dev and prod (add it to each host's .env). Optional: an
# empty MONGODB_URI disables Mongo — the client returns ErrMongoUnavailable and
# callers degrade gracefully. No feature uses Mongo yet (see docs/ARCHITECTURE.md §10).
MONGODB_URI=mongodb://user:password@mongodb.corpberry.com/admin
# App database name. Defaults to "site-of-tools" if unset.
MONGODB_DATABASE=site-of-tools
