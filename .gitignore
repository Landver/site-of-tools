# data & secrets
tools/iptools/assets/
.env
# per-host prod overrides (layered by docker-compose); create from .env.example
.env.prod

# Claude Code worktree state (not part of the project)
.claude/worktrees/
# local git worktrees (agent/dev isolation, not part of the project)
.worktrees/

# build artifacts
# (comments MUST be on their own line — gitignore has no inline comments)
tmp/
# generated by Tailwind (make css / Docker build)
shared/static/css/styles.css

# build output & fetched binaries (see `make tools`)
/bin/
/shared/tailwindcss
*.exe
# downloaded Go toolchain tarball (install to /usr/local, don't commit)
*.tar.gz
